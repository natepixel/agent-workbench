# Example environment file for this repo template.
#
# Rules:
# - Copy values you actually use into `.env` (never commit `.env`)
# - Document every required secret or config value here
# - Use placeholder or example values only
# - `./scripts/check-env.sh` verifies that every key listed here exists in `.env`
#
# If a new secret or config variable is needed:
# 1. add it here with a comment explaining purpose
# 2. add the real value to local `.env`
# 3. update scripts or docs if validation rules change

# Core
APP_NAME=agent-workbench
APP_ENV=local

# Example local ports
APP_PORT=
API_PORT=
WEB_PORT=

# Example deploy-related values
DEV_URL=
MAIN_URL=

# Example API keys / secrets
# Fill these in locally if needed.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_PROJECT=
GITHUB_TOKEN=

# Notes
# - Keep all real secrets in .env only.
# - If a new secret is needed, document it here with a comment.
# - Scripts should validate required secrets without printing values.
